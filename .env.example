APP_NAME="CrossFit Avignon API"
ENVIRONMENT="development"

# Exemple: postgresql+psycopg2://user:password@host:port/database
DATABASE_URL="postgresql+psycopg2://postgres:postgres@localhost:5432/crossfit_avignon"

# Origines autorisées pour le frontend (séparées par des virgules si plusieurs)
# Exemple: "http://localhost:5173,https://crossfitavignon.fr"
BACKEND_CORS_ORIGINS="http://localhost:5173"

# Email de notification (optionnel, pour usage futur)
NOTIFICATION_EMAIL=""

# JWT Auth — générer avec: python3 -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY="change-me-in-production-use-a-long-random-string"
ACCESS_TOKEN_EXPIRE_MINUTES=480

